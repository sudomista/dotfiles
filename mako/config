font=JetBrains Mono Bold 12
background-color=#1f1f28
text-color=#dcd7ba
border-color=#dcd7ba
border-size=2
border-radius=0
width=300
height=100
margin=15
padding=10
icons=1
max-icon-size=64

max-history=5
sort=-time
default-timeout=5000

on-button-left=dismiss
on-button-middle=none
on-button-right=dismiss-all
on-touch=dismiss

[urgency=low]
border-color=#dcd7ba
default-timeout=2000

[urgency=high]
border-color=#dcd7ba
default-timeout=0
